; Generated by Sim Panel Manager — DO NOT EDIT MANUALLY
; Board: {{ board.name }} | Product: {{ board.identity.usbProduct }}
; Regenerate from the Sim Panel Manager app.

[env:{{ board.env_name }}]
platform = atmelavr
board = {{ board.board_type }}_custom
framework = arduino
board_json_dir = boards

lib_deps =
    mheironimus/Joystick@^2.1.1

build_flags =
    -DUSB_VID={{ board.identity.usbVidHex }}
    -DUSB_PID={{ board.identity.usbPidHex }}
    -DUSB_PRODUCT="{{ board.identity.usbProduct }}"
    -DUSB_MANUFACTURER="Sim Panel Manager"

monitor_speed = 9600
