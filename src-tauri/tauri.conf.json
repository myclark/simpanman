{
  "productName": "Sim Panel Manager",
  "version": "0.1.0",
  "identifier": "de.mpg.aei.simpanman",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Sim Panel Manager",
        "width": 1400,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/pio"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/myclark/simpanman/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "REPLACE_WITH_OUTPUT_OF_npx_tauri_signer_generate"
    },
    "shell": {
      "open": false
    }
  }
}
